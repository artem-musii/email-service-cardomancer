DATABASE_URL=postgres://postgres:postgres@localhost:5434/email_db
RABBITMQ_URL=amqp://localhost:5672
RESEND_API_KEY=
FROM_EMAIL=noreply@example.com
PORT=3002
LOG_LEVEL=debug
